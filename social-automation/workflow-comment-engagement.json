    {
      "parameters": {
        "method": "POST",
        "url": "https://api.linkedin.com/v2/socialActions/urn:li:ugcPost:POST_ID/comments",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{ $env.MAXPROMO_LINKEDIN_TOKEN }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"actor\": \"urn:li:organization:{{ $env.MAXPROMO_LINKEDIN_ORG_ID }}\",\n  \"message\": {\n    \"text\": \"{{ $json.replyText }}\"\n  }\n}",
        "options": {}
      },
      "id": "send-linkedin-reply",
      "name": "Send LinkedIn Reply (DISABLED — setup pending)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2020, 540],
      "disabled": true,
      "notes": "DISABLED — enable when LinkedIn Page is set up"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO social_comments (platform, comment_id, commenter_name, comment_text, reply_text, reply_sent, replied_at) VALUES ('{{ $json.platform }}', '{{ $json.commentId }}', '{{ $json.authorName }}', '{{ $json.text.replace(/'/g, \"''\") }}', '{{ $json.replyText.replace(/'/g, \"''\") }}', true, NOW()) ON CONFLICT (comment_id) DO NOTHING"
      },
