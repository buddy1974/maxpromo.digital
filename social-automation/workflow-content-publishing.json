{
  "name": "MaxPromo Digital — Content Publishing",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            { "triggerAtHour": 8, "triggerAtMinute": 0 },
            { "triggerAtHour": 19, "triggerAtMinute": 0 }
          ]
        }
      },
      "id": "schedule-trigger",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [240, 300]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT * FROM social_posts WHERE status = 'approved' AND (scheduled_for IS NULL OR scheduled_for <= NOW()) ORDER BY created_at ASC LIMIT 10"
      },
      "id": "neon-read-queue",
      "name": "Read Content Queue (Neon)",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [460, 300],
      "credentials": {
        "postgres": {
          "id": "NEON_CREDENTIAL_ID",
          "name": "MaxPromo Neon DB"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const now = new Date();\nconst currentHour = now.getHours();\n\nconst isMorningRun = currentHour < 13;\nconst isEveningRun = currentHour >= 13;\n\nconst filtered = [];\n\nfor (const item of $input.all()) {\n  const window = (item.json.scheduled_window || 'ANY').toUpperCase().trim();\n\n  if (window === 'ANY' || window === '') {\n    filtered.push(item);\n    continue;\n  }\n  if (window === 'MORNING' && isMorningRun) {\n    filtered.push(item);\n    continue;\n  }\n  if (window === 'EVENING' && isEveningRun) {\n    filtered.push(item);\n    continue;\n  }\n}\n\nreturn filtered;"
      },
      "id": "time-window-filter",
      "name": "Time Window Filter",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-api-key", "value": "ANTHROPIC_API_KEY_ENTER_IN_N8N" },
            { "name": "anthropic-version", "value": "2023-06-01" },
            { "name": "content-type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-sonnet-4-5\",\n  \"max_tokens\": 400,\n  \"system\": \"You are the social media voice of MaxPromo Digital, an AI automation agency.\\n\\nBRAND VOICE:\\n- Confident and expert, never salesy\\n- Use specific numbers and outcomes\\n- Short punchy sentences. High impact.\\n- No corporate buzzwords\\n\\nPLATFORM RULES:\\n- Facebook: 100-150 words, conversational, end with a question, 2-3 hashtags\\n- Instagram: 80-110 words, punchy, 8-10 hashtags at end only\\n- FB+IG: use Instagram format\\n- YouTube: 100-150 words, educational hook, direct CTA\\n\\nALWAYS end every post with:\\n\\u2192 Free audit: https://maxpromo.digital/automation-audit\\n\\nNever escape quotes with backslashes. Write naturally. No JSON escaping in your output.\\n\\nReturn ONLY the caption. No explanation. No JSON.\",\n  \"messages\": [{\"role\": \"user\", \"content\": \"Platform: {{ $json.platform }}\\nContent type: {{ $json.content_type }}\\nSector: {{ $json.sector }}\\nTopic: {{ $json.topic }}\\nWrite an optimised caption.\"}]\n}",
        "options": {}
      },
      "id": "claude-caption-gen",
      "name": "AI Caption Generation (Claude)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [900, 300]
    },
    {
      "parameters": {
        "jsCode": "const response = $json.content;\nlet caption = '';\nif (Array.isArray(response)) {\n  caption = response\n    .filter(b => b.type === 'text')\n    .map(b => b.text)\n    .join('');\n} else if (typeof response === 'string') {\n  caption = response;\n}\ncaption = caption.trim();\nconst finalCaption = caption.replace(/\"/g, '\\\\\"');\nreturn [{\n  json: {\n    ...$('Time Window Filter').item.json,\n    FinalCaption: finalCaption,\n    RawCaption: caption\n  }\n}];"
      },
      "id": "merge-caption",
      "name": "Merge Caption",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 300]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": { "caseSensitive": false },
                "conditions": [{ "leftValue": "={{ $json.platform }}", "rightValue": "Facebook", "operator": { "type": "string", "operation": "equals" } }],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "Facebook"
            },
            {
              "conditions": {
                "options": { "caseSensitive": false },
                "conditions": [{ "leftValue": "={{ $json.platform }}", "rightValue": "Instagram", "operator": { "type": "string", "operation": "equals" } }],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "Instagram"
            },
            {
              "conditions": {
                "options": { "caseSensitive": false },
                "conditions": [{ "leftValue": "={{ $json.platform }}", "rightValue": "YouTube", "operator": { "type": "string", "operation": "equals" } }],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "YouTube"
            },
