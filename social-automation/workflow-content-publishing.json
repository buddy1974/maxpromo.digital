    {
      "parameters": {
        "jsCode": "const postResponse = $json;\nconst mergeItem = $('Merge Caption').item.json;\n\nconst postUrl = postResponse.id\n  ? `https://www.facebook.com/${postResponse.id}`\n  : postResponse.postId\n  ? `https://www.youtube.com/post/${postResponse.postId}`\n  : '';\n\nreturn [{\n  json: {\n    post_id: mergeItem.id,\n    platform_post_id: postResponse.id || postResponse.postId || '',\n    platform: mergeItem.platform,\n    postUrl\n  }\n}];"
      },
