# ──────────────────────────────────────────────────────────────────────
# .env.local.example — copy this to .env.local and fill in real values.
# Validated at boot by lib/env.ts.
# ──────────────────────────────────────────────────────────────────────

# === Database (REQUIRED) ============================================
# Neon serverless connection string. Get from Neon dashboard.
NEON_DATABASE_URL=postgresql://user:pass@ep-xxxx.eu-central-1.aws.neon.tech/maxpromo?sslmode=require

# === Auth (REQUIRED) ================================================
# Server-side OS password. Min 8 chars. Never commit the real value.
# IMPORTANT: if your password contains '#', '$', or whitespace, wrap it
# in DOUBLE QUOTES — otherwise dotenv treats '#' as the start of a comment
# and silently strips it. Example: OS_PASSWORD="Texas2026#"
OS_PASSWORD=change-me-set-real-password

# Cookie-signing secret. Min 32 chars; use 64 random bytes for safety.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
OS_SESSION_SECRET=change-me-paste-the-generated-secret-here

# === AI providers (at least one REQUIRED in production) =============
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...    # optional fallback

# === Email (REQUIRED in production) =================================
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=MAXPROMO DIGITAL <info@maxpromo.digital>
CONTACT_EMAIL=info@maxpromo.digital

# === Optional ========================================================
# Password gate for /portfolio
PORTFOLIO_PASSWORD=set-a-portfolio-access-code
